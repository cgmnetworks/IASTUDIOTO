rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Entities Validations
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.keys().size() == 2 &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidWaLink(data) {
      return data.keys().hasAll(['phone', 'url', 'createdAt']) &&
             data.phone is string && data.phone.size() <= 50 &&
             data.url is string && data.url.size() <= 1000 &&
             data.createdAt is string && data.createdAt.size() <= 60 &&
             (data.keys().hasAny(['message']) ? (data.message is string && data.message.size() <= 2000) : true);
    }
    
    function isValidWebsite(data) {
      return data.keys().hasAll(['prompt', 'status', 'createdAt']) &&
             data.prompt is string && data.prompt.size() <= 10000 &&
             data.status is string && data.status.size() <= 50 &&
             data.createdAt is string && data.createdAt.size() <= 60;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && 
                       isValidId(userId) && 
                       request.auth.uid == userId && 
                       isValidUser(incoming());
      allow update: if isSignedIn() &&
                       isValidId(userId) && 
                       request.auth.uid == userId &&
                       isValidUser(incoming()) &&
                       incoming().email == existing().email &&
                       incoming().createdAt == existing().createdAt;
                       
      // WhatsApp Links Subcollection
      match /whatsapp_links/{linkId} {
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && 
                         isValidId(userId) && isValidId(linkId) &&
                         request.auth.uid == userId && 
                         isValidWaLink(incoming());
        allow update: if isSignedIn() &&
                         isValidId(userId) && isValidId(linkId) &&
                         request.auth.uid == userId &&
                         isValidWaLink(incoming()) &&
                         incoming().createdAt == existing().createdAt;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
      
      // Website Projects Subcollection
      match /websites/{siteId} {
        allow read, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && 
                         isValidId(userId) && isValidId(siteId) &&
                         request.auth.uid == userId && 
                         isValidWebsite(incoming());
        allow update: if isSignedIn() &&
                         isValidId(userId) && isValidId(siteId) &&
                         request.auth.uid == userId &&
                         isValidWebsite(incoming()) &&
                         incoming().createdAt == existing().createdAt;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
